#define R5 0x0000001f
#define C5 0x00108421

const char* const emojis[] = { "🍉", "🍒", "🍋", "🔔", "💰", "💎" };

void
print_bitmaps(board_t b) {
    for(int j = 0; j < NUM_SYMBOLS; j++) {
        printf("[%s]:\n", emojis[j]);
        for(int i = 0; i < LEN_SLOTS; i++) {
            putchar((b.bitmaps[j] & (1u << i) ? 'X' : '.'));
            if(i % 5 == 4) putchar('\n');
        }
    }
}

void
print_symbols(board_t b) {
    for(int i = 0; i < LEN_SLOTS; i+= 5) {
        printf("%s %s %s %s %s\n",
        emojis[b.ids[i + 0]], emojis[b.ids[i + 1]],
        emojis[b.ids[i + 2]], emojis[b.ids[i + 3]],
        emojis[b.ids[i + 4]]);
    }
}

